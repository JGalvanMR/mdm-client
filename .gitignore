### JetBrains / IntelliJ / Android Studio
# Esta sección sigue la recomendación de JetBrains: comparte la estructura, ignora lo personal.
*.iml
*.ipr
*.iws
/.idea/*

# NO IGNORAR (Permitir configuración compartida del equipo)
!.idea/codeStyles/
!.idea/copyright/
!.idea/compiler.xml
!.idea/inspectionProfiles/
!.idea/runConfigurations/
!.idea/vcs.xml
!.idea/scopes/
!.idea/externalDependencies.xml
!.idea/fileTemplates/
!.idea/icon.svg

# IGNORAR (Configuración puramente personal o temporal)
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf
.idea/**/contentModel.xml
.idea/**/dataSources/
.idea/**/dataSources.local.xml
.idea/caches/
.idea/sonarlint

